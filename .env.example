ADMIN_ACCESS_PASSWORD=change-me
# At least 32 characters. Used to sign the httpOnly admin session cookie.
SESSION_SECRET=replace-with-at-least-32-random-characters
# SQLite file URL. The default parent directory is created by db/app startup helpers.
DATABASE_URL=file:./data/workbench.sqlite
AI_API_BASE_URL=https://api.example.com/v1
AI_API_KEY=replace-with-server-only-key
AI_MODEL=replace-with-model-name
